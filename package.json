{
  "name": "plus-ai-landing",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --open /index.dev.html",
    "build": "tsc -b && vite build && vite build --config vite.ssr.config.ts && node scripts/prerender.mjs",
    "preview": "vite preview",
    "verify": "node scripts/verify-build.mjs",
    "check": "npm run build && npm run verify"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.3",
    "vite": "8.1.5",
    "typescript": "7.0.2",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3"
  }
}
